# FastAPI Settings
DEBUG=True
APP_NAME="SAJAG AI - Smart Disaster Response & Rescue Coordination Platform"
APP_VERSION="1.0.0"

# MongoDB Settings - encoded password
MONGODB_URL=
DATABASE_NAME=


# JWT & Cookie Settings
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_DAYS=7

# Cookie Settings (HttpOnly for security)
COOKIE_NAME=access_token
COOKIE_SECURE=False
COOKIE_HTTPONLY=True
COOKIE_SAMESITE=lax

# Server Settings
HOST=0.0.0.0
PORT=8000

# AI/ML Settings
YOLO_MODEL=yolov8n.pt
CONFIDENCE_THRESHOLD=0.5

# Density Thresholds
DENSITY_LOW=30
DENSITY_MEDIUM=60
DENSITY_HIGH=85
API_KEY=
